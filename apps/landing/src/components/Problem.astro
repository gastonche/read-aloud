---
import Icon from './Icon.astro';

const pains = [
  {
    icon: 'fileText',
    before: '47 tabs open “to read later.”',
    after: 'Send them to your ears and clear them on your commute.',
  },
  {
    icon: 'gauge',
    before: 'Eyes fried after a day of screens.',
    after: 'Lean back, close your eyes, and keep absorbing.',
  },
  {
    icon: 'languages',
    before: 'Long PDFs you keep “starting tomorrow.”',
    after: 'Press play and finish that report while you cook.',
  },
];
---

<section class="mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-28">
  <div class="reveal mx-auto max-w-2xl text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.16em] text-accent">The honest truth</p>
    <h2 class="mt-3 font-display text-[clamp(1.9rem,4vw,2.9rem)] font-semibold leading-tight tracking-tight text-ink dark:text-white">
      You don&rsquo;t have a reading problem.
      <br class="hidden sm:block" /> You have a <span class="mark">time</span> problem.
    </h2>
    <p class="mt-4 text-lg leading-relaxed text-ink-soft dark:text-slate-300">
      There&rsquo;s more worth reading than any pair of eyes can keep up with. ReadAloud
      doesn&rsquo;t ask you to read faster — it lets you read with your ears, hands-free,
      anywhere, while keeping the words in front of you.
    </p>
  </div>

  <div class="reveal mt-14 grid gap-5 md:grid-cols-3">
    {
      pains.map((p) => (
        <div class="group rounded-3xl border border-paper-dim bg-paper p-6 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-slate-900/5 dark:border-night-line dark:bg-night-soft">
          <span class="grid h-11 w-11 place-items-center rounded-2xl bg-paper-warm text-ink-soft dark:bg-night dark:text-slate-300">
            <Icon name={p.icon} size={20} />
          </span>
          <p class="mt-5 text-sm font-semibold text-ink-faint line-through decoration-rose-300 decoration-2">
            {p.before}
          </p>
          <p class="mt-2 flex gap-2 text-[15px] font-medium leading-relaxed text-ink dark:text-white">
            <Icon name="arrowRight" size={18} class="mt-0.5 shrink-0 text-accent" />
            <span>{p.after}</span>
          </p>
        </div>
      ))
    }
  </div>
</section>
