---
import Icon from './Icon.astro';

// NOTE: placeholder testimonials for the marketing mockup. Replace with real,
// attributable quotes (and permission) before publishing.
const quotes = [
  {
    quote:
      'I get through three times the research papers now. The word highlighting means I never lose my spot when I glance away.',
    name: 'Dr. Lena Ortiz',
    role: 'Postdoctoral researcher',
    grad: 'from-rose-200 to-amber-200',
  },
  {
    quote:
      'As someone with dyslexia, following along while it reads has been the difference between finishing an article and giving up halfway.',
    name: 'Marcus Bell',
    role: 'Product designer',
    grad: 'from-sky-200 to-indigo-200',
  },
  {
    quote:
      'I “read” my entire newsletter backlog on my morning walk. The voices are good enough that I forget it isn&rsquo;t a podcast.',
    name: 'Priya Nair',
    role: 'Founder, two-time newsletter hoarder',
    grad: 'from-violet-200 to-fuchsia-200',
  },
];
---

<section class="mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-28">
  <div class="reveal mx-auto max-w-2xl text-center">
    <div class="flex items-center justify-center gap-1 text-accent">
      {Array.from({ length: 5 }).map(() => <Icon name="star" size={20} class="fill-current" />)}
    </div>
    <h2 class="mt-4 font-display text-[clamp(1.9rem,4vw,2.9rem)] font-semibold leading-tight tracking-tight text-ink dark:text-white">
      People stop reading and start finishing
    </h2>
  </div>

  <div class="reveal mt-14 grid gap-5 md:grid-cols-3">
    {
      quotes.map((q) => (
        <figure class="flex h-full flex-col rounded-3xl border border-paper-dim bg-paper p-7 dark:border-night-line dark:bg-night-soft">
          <Icon name="quote" size={26} class="text-accent/40" />
          <blockquote
            class="mt-3 flex-1 text-[15px] leading-relaxed text-ink dark:text-slate-200"
            set:html={`&ldquo;${q.quote}&rdquo;`}
          />
          <figcaption class="mt-6 flex items-center gap-3">
            <span class={`h-10 w-10 shrink-0 rounded-full bg-gradient-to-br ${q.grad}`} />
            <div>
              <p class="text-sm font-semibold text-ink dark:text-white">{q.name}</p>
              <p class="text-xs text-ink-faint">{q.role}</p>
            </div>
          </figcaption>
        </figure>
      ))
    }
  </div>
</section>
