---
import Icon from './Icon.astro';
const chromeStore = 'https://chrome.google.com/webstore';
---

<section class="mx-auto max-w-7xl px-5 pb-24 lg:px-8">
  <div
    class="reveal relative overflow-hidden rounded-[2rem] bg-ink px-6 py-16 text-center text-white sm:px-12 lg:py-20 dark:bg-night-soft dark:ring-1 dark:ring-night-line"
  >
    <div class="pointer-events-none absolute inset-0 -z-0 bg-[radial-gradient(50%_60%_at_50%_0%,rgba(124,124,255,0.25)_0%,transparent_60%)]"></div>
    <div class="relative">
      <h2 class="mx-auto max-w-2xl font-display text-[clamp(2rem,4.5vw,3.2rem)] font-semibold leading-[1.08] tracking-tight">
        Your reading list isn&rsquo;t getting shorter.
        <br class="hidden sm:block" />
        <span class="text-accent-soft">Let it read itself to you.</span>
      </h2>
      <p class="mx-auto mt-5 max-w-xl text-lg text-slate-300">
        Free to install, free to use, no account. Add ReadAloud and listen to the
        first thing on your list in under a minute.
      </p>
      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={chromeStore}
          class="group inline-flex items-center justify-center gap-2.5 rounded-2xl bg-white px-7 py-4 text-base font-semibold text-ink shadow-xl transition-transform hover:-translate-y-0.5"
        >
          <Icon name="chrome" size={20} />
          Add to Chrome — it&rsquo;s free
          <Icon name="arrowRight" size={18} class="transition-transform group-hover:translate-x-0.5" />
        </a>
        <a
          href="#mobile"
          class="inline-flex items-center justify-center gap-2 rounded-2xl px-5 py-4 text-base font-semibold text-white ring-1 ring-white/20 transition-colors hover:bg-white/10"
        >
          Get the mobile apps first
        </a>
      </div>
      <p class="mt-6 text-sm text-slate-400">Free voices forever · No account · Private by design</p>
    </div>
  </div>
</section>
