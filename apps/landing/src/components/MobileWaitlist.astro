---
import Icon from './Icon.astro';
---

<section
  id="mobile"
  class="scroll-mt-20 mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-28"
>
  <div
    class="reveal relative overflow-hidden rounded-[2rem] border border-accent/20 bg-gradient-to-br from-ink to-accent-ink px-6 py-12 text-white sm:px-12 lg:py-16 dark:border-accent-bright/25"
  >
    <div
      class="pointer-events-none absolute -right-20 -top-24 h-72 w-72 rounded-full bg-accent-violet/30 blur-3xl"
    >
    </div>
    <div
      class="pointer-events-none absolute -bottom-24 -left-16 h-72 w-72 rounded-full bg-accent-bright/30 blur-3xl"
    >
    </div>

    <div class="relative grid items-center gap-10 lg:grid-cols-[1.1fr_0.9fr]">
      <div>
        <span
          class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-white ring-1 ring-white/20"
        >
          <span class="relative flex h-1.5 w-1.5">
            <span
              class="absolute inline-flex h-full w-full animate-ping rounded-full bg-white opacity-75"
            ></span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-white"
            ></span>
          </span>
          Coming soon
        </span>
        <h2
          class="mt-5 font-display text-[clamp(1.9rem,4vw,2.9rem)] font-semibold leading-tight tracking-tight"
        >
          Take your reading list <span class="text-accent-soft"
            >off the desk</span
          >
        </h2>
        <p class="mt-4 max-w-md text-lg leading-relaxed text-slate-200">
          ReadAloud for iOS and Android is on the way — the same synced
          highlighting and natural voices, built for the moments you&rsquo;re
          nowhere near a laptop. Be the first in line.
        </p>

        <div class="mt-7 flex flex-wrap items-center gap-3">
          <span
            class="inline-flex items-center gap-2 rounded-xl bg-white/10 px-4 py-2.5 text-sm font-semibold ring-1 ring-white/15"
          >
            <Icon name="apple" size={18} /> iOS — soon
          </span>
          <span
            class="inline-flex items-center gap-2 rounded-xl bg-white/10 px-4 py-2.5 text-sm font-semibold ring-1 ring-white/15"
          >
            <Icon name="android" size={18} /> Android — soon
          </span>
        </div>
      </div>

      <div
        class="rounded-3xl bg-white/10 p-6 ring-1 ring-white/15 backdrop-blur-sm"
      >
        <form data-waitlist novalidate>
          <div data-waitlist-fields>
            <label for="wl-email" class="block text-sm font-semibold text-white"
              >Get launch access</label
            >
            <p class="mt-1 text-xs text-slate-300">
              No spam — one email when the apps land.
            </p>
            <div class="mt-3 flex flex-col gap-2.5 sm:flex-row">
              <input
                id="wl-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder="you@example.com"
                class="w-full rounded-xl border-0 bg-white/95 px-4 py-3 text-sm text-ink placeholder:text-ink-faint focus:outline-none focus:ring-2 focus:ring-white"
              />
              <button
                type="submit"
                class="shrink-0 rounded-xl bg-white px-5 py-3 text-sm font-semibold text-accent-ink transition-transform hover:-translate-y-0.5"
              >
                Notify me
              </button>
            </div>
          </div>
          <div data-waitlist-ok class="hidden">
            <div class="flex items-center gap-3">
              <span
                class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-white text-accent-ink"
              >
                <Icon name="check" size={20} />
              </span>
              <div>
                <p class="text-sm font-semibold text-white">
                  You&rsquo;re on the list.
                </p>
                <p class="text-xs text-slate-300">
                  We&rsquo;ll email you the moment the apps go live.
                </p>
              </div>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
