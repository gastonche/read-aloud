---
// The ReadAloud mark: text lines becoming sound waves ("read aloud"), white on
// the brand indigo→violet gradient. Shared by the nav and footer so the brand
// chip is defined once. `id` keeps each instance's gradient unique on a page.
interface Props {
  size?: number;
  class?: string;
}
const { size = 36, class: klass = '' } = Astro.props;
const gid = `ra-logo-${Math.random().toString(36).slice(2, 8)}`;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 100 100"
  role="img"
  aria-label="ReadAloud"
  class={klass}
>
  <defs>
    <linearGradient id={gid} x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#6366f1"></stop>
      <stop offset="1" stop-color="#8b5cf6"></stop>
    </linearGradient>
  </defs>
  <rect width="100" height="100" rx="26" fill={`url(#${gid})`}></rect>
  <rect x="22" y="35" width="28" height="9" rx="4.5" fill="#fff"></rect>
  <rect x="22" y="49" width="20" height="9" rx="4.5" fill="#fff"></rect>
  <rect x="22" y="63" width="28" height="9" rx="4.5" fill="#fff"></rect>
  <path
    d="M60 39a15 15 0 0 1 0 22"
    stroke="#fff"
    stroke-width="8"
    fill="none"
    stroke-linecap="round"></path>
  <path
    d="M71 31a30 30 0 0 1 0 38"
    stroke="#fff"
    stroke-width="8"
    fill="none"
    stroke-linecap="round"></path>
</svg>
