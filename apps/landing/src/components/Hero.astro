---
import Icon from './Icon.astro';
import { INSTALL_URL as chromeStore } from '../config';
---

<section id="top" class="relative overflow-hidden">
  <!-- separate gradient layers so dark never inherits the light one -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(60%_50%_at_50%_-10%,var(--color-accent-soft)_0%,transparent_60%)] dark:hidden"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-0 -z-10 hidden bg-[radial-gradient(60%_50%_at_50%_-10%,rgba(99,102,241,0.18)_0%,transparent_65%)] dark:block"
  >
  </div>

  <div
    class="mx-auto grid max-w-7xl items-center gap-12 px-5 pb-16 pt-14 lg:grid-cols-[1.05fr_0.95fr] lg:gap-8 lg:px-8 lg:pb-24 lg:pt-20"
  >
    <div class="max-w-xl">
      <a
        href="#mobile"
        class="inline-flex items-center gap-2 rounded-full border border-accent/20 bg-accent-soft/70 px-3 py-1 text-xs font-semibold text-accent-ink transition-colors hover:bg-accent-soft dark:border-accent-bright/30 dark:bg-accent-bright/10 dark:text-accent-soft"
      >
        <span class="relative flex h-1.5 w-1.5">
          <span
            class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-bright opacity-75"
          ></span>
          <span
            class="relative inline-flex h-1.5 w-1.5 rounded-full bg-accent-bright"
          ></span>
        </span>
        iOS &amp; Android apps coming soon — join the list
      </a>

      <h1
        class="mt-5 font-display text-[clamp(2.4rem,6vw,3.9rem)] font-semibold leading-[1.05] tracking-[-0.02em] text-ink dark:text-white"
      >
        Stop reading everything.
        <br class="hidden sm:block" />
        <span class="mark-sweep">Start listening</span> to it.
      </h1>

      <p class="mt-5 text-lg leading-relaxed text-ink-soft dark:text-slate-300">
        ReadAloud turns any web page, PDF, or article into clear, natural speech
        — and highlights <span class="mark"
          >every word as it&rsquo;s spoken</span
        >, right on the page. Clear your reading backlog on your commute, your
        walk, or while your eyes rest.
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href={chromeStore}
          class="group inline-flex items-center justify-center gap-2.5 rounded-2xl bg-accent px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-accent/25 transition-all hover:-translate-y-0.5 hover:shadow-xl hover:shadow-accent/30"
        >
          <Icon name="chrome" size={20} />
          Add to Chrome — it&rsquo;s free
          <Icon
            name="arrowRight"
            size={18}
            class="transition-transform group-hover:translate-x-0.5"
          />
        </a>
        <a
          href="#how"
          class="inline-flex items-center justify-center gap-2 rounded-2xl border border-paper-dim bg-paper px-5 py-3.5 text-base font-semibold text-ink transition-colors hover:bg-paper-warm dark:border-night-line dark:bg-night-soft dark:text-white dark:hover:bg-night-line"
        >
          <Icon name="play" size={16} class="fill-current stroke-none" />
          See how it works
        </a>
      </div>

      <div
        class="mt-7 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-ink-soft dark:text-slate-400"
      >
        <span class="inline-flex items-center gap-1.5">
          <Icon name="check" size={16} class="text-accent" /> No account needed
        </span>
        <span class="inline-flex items-center gap-1.5">
          <Icon name="check" size={16} class="text-accent" /> Free voices forever
        </span>
        <span class="inline-flex items-center gap-1.5">
          <Icon name="check" size={16} class="text-accent" /> Private by design
        </span>
      </div>
    </div>

    <div class="reveal in relative mx-auto w-full max-w-md lg:max-w-none">
      <div class="relative animate-float">
        <div
          class="rounded-3xl border border-paper-dim bg-paper p-6 shadow-2xl shadow-slate-900/10 sm:p-8 dark:border-night-line dark:bg-night-soft dark:shadow-black/40"
        >
          <div class="mb-5 flex items-center gap-1.5">
            <span class="h-3 w-3 rounded-full bg-paper-dim dark:bg-night-line"
            ></span>
            <span class="h-3 w-3 rounded-full bg-paper-dim dark:bg-night-line"
            ></span>
            <span class="h-3 w-3 rounded-full bg-paper-dim dark:bg-night-line"
            ></span>
            <span class="ml-3 truncate text-xs text-ink-faint"
              >the-economist.com/briefing</span
            >
          </div>

          <p
            class="font-display text-xl font-semibold text-ink dark:text-white"
          >
            The quiet revolution in how we read
          </p>
          <div
            class="mt-4 space-y-2.5 text-[15px] leading-relaxed text-ink-soft dark:text-slate-300"
          >
            <p>
              For most of the last century, reading meant sitting still with a
              page.
            </p>
            <p>
              <span class="mark"
                >Today the words can come to you —
                <span class="rounded-[0.35em] bg-accent px-1 text-white"
                  >spoken aloud</span
                >
                and highlighted in perfect sync.</span
              >
            </p>
            <p class="opacity-60">
              The result feels less like a screen reader and more like a great
              audiobook narrator who never loses your place.
            </p>
          </div>

          <div
            class="mt-6 flex items-center gap-3 rounded-2xl bg-paper-warm p-3 dark:bg-night"
          >
            <span
              class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-gradient-to-br from-accent-bright to-accent-violet text-white"
            >
              <Icon name="headphones" size={18} />
            </span>
            <div class="min-w-0 flex-1">
              <p
                class="truncate text-sm font-semibold text-ink dark:text-white"
              >
                Aria — Premium voice
              </p>
              <p class="text-xs text-ink-faint">
                Warm &amp; natural · English (US)
              </p>
            </div>
            <div class="flex items-end gap-0.5" aria-hidden="true">
              <span
                class="eq-bar h-4 w-1 rounded-full bg-accent"
                style="animation-delay:0ms"></span>
              <span
                class="eq-bar h-5 w-1 rounded-full bg-accent"
                style="animation-delay:150ms"></span>
              <span
                class="eq-bar h-3 w-1 rounded-full bg-accent"
                style="animation-delay:300ms"></span>
              <span
                class="eq-bar h-5 w-1 rounded-full bg-accent-violet"
                style="animation-delay:80ms"></span>
            </div>
          </div>
        </div>

        <div
          class="absolute -right-3 top-1/2 hidden -translate-y-1/2 flex-col items-center gap-2.5 rounded-full border border-paper-dim bg-paper/95 px-2 py-3 shadow-xl shadow-slate-900/15 backdrop-blur sm:flex dark:border-night-line dark:bg-night-soft/95"
        >
          <span class="text-[9px] font-bold tracking-wide text-accent">EN</span>
          <span
            class="grid h-11 w-11 place-items-center rounded-full bg-gradient-to-br from-accent-bright to-accent-violet text-white shadow-md shadow-accent/30"
          >
            <Icon name="pause" size={18} class="fill-current stroke-none" />
          </span>
          <span
            class="rounded-full border border-paper-dim px-1.5 py-0.5 text-[10px] font-bold text-accent dark:border-night-line"
            >1×</span
          >
          <span
            class="h-7 w-7 rounded-full bg-gradient-to-br from-amber-200 to-rose-200"
          ></span>
          <span class="text-[9px] tabular-nums text-ink-faint">2/8</span>
        </div>
      </div>

      <div
        class="absolute -bottom-4 -left-3 flex items-center gap-2 rounded-2xl border border-paper-dim bg-paper px-3.5 py-2.5 shadow-xl shadow-slate-900/10 dark:border-night-line dark:bg-night-soft"
      >
        <span
          class="grid h-9 w-9 place-items-center rounded-xl bg-accent-soft text-accent dark:bg-accent-bright/15"
        >
          <Icon name="fileText" size={18} />
        </span>
        <div class="leading-tight">
          <p class="text-xs font-semibold text-ink dark:text-white">
            Also reads files
          </p>
          <p class="text-[11px] text-ink-faint">PDF · EPUB · DOCX · TXT</p>
        </div>
      </div>
    </div>
  </div>
</section>
