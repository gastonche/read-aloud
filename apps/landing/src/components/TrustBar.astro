---
const stats = [
  { value: '30+', label: 'Languages read aloud' },
  { value: '4', label: 'File types: PDF, EPUB, DOCX, TXT' },
  { value: '3×', label: 'Top reading speed (0.5×–3×)' },
  { value: '$0', label: 'Free voices, no account needed' },
];
---

<section
  class="border-y border-paper-dim bg-paper-warm dark:border-night-line dark:bg-night-soft"
>
  <div class="mx-auto max-w-7xl px-5 py-8 lg:px-8">
    <p
      class="text-center text-xs font-semibold uppercase tracking-[0.18em] text-ink-faint"
    >
      Built for everyone with more to read than time to read it
    </p>
    <dl class="reveal mt-6 grid grid-cols-2 gap-x-6 gap-y-6 sm:grid-cols-4">
      {
        stats.map((s) => (
          <div class="text-center">
            <dt class="font-display text-3xl font-semibold text-ink dark:text-white">
              {s.value}
            </dt>
            <dd class="mx-auto mt-1 max-w-[16ch] text-xs leading-snug text-ink-soft dark:text-slate-400">
              {s.label}
            </dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
