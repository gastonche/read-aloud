{
  "name": "readaloud",
  "private": true,
  "version": "0.1.0",
  "description": "ReadAloud — a Speechify-style MV3 extension that reads pages and documents aloud with synced highlighting.",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  }
}
