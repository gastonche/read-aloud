{
  "name": "readaloud",
  "private": true,
  "version": "0.3.0",
  "description": "ReadAloud — a Speechify-style MV3 extension that reads pages and documents aloud with synced highlighting.",
  "license": "MIT",
  "author": "Gaston <gastonnkh@gmail.com>",
  "homepage": "https://github.com/gastonche/read-aloud#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/gastonche/read-aloud.git"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,astro,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,astro,css,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "turbo": "^2.9.16",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  }
}
